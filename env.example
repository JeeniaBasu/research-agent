# =============================================================================
# AI-Powered Research Agent — Environment Variables Template
# =============================================================================
# INSTRUCTIONS:
#   1. Copy this file and rename it to ".env"
#   2. Fill in your IBM Cloud credentials
#   3. Never commit your .env file to version control
# =============================================================================

# -----------------------------------------------------------------------------
# IBM Watsonx.ai Configuration (REQUIRED)
# -----------------------------------------------------------------------------
# Get from: https://cloud.ibm.com/ → Manage → Access (IAM) → API Keys
IBM_CLOUD_API_KEY=your_ibm_cloud_api_key_here

# Get from: IBM Watsonx.ai Studio → Your Project → Manage → General → Details
WATSONX_PROJECT_ID=your_watsonx_project_id_here

# IBM Watsonx.ai service endpoint (choose your region)
# US South:  https://us-south.ml.cloud.ibm.com
# EU DE:     https://eu-de.ml.cloud.ibm.com
# EU GB:     https://eu-gb.ml.cloud.ibm.com
# JP TOK:    https://jp-tok.ml.cloud.ibm.com
# AU SYD:    https://au-syd.ml.cloud.ibm.com
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# -----------------------------------------------------------------------------
# Flask Application Configuration
# -----------------------------------------------------------------------------
FLASK_SECRET_KEY=change_this_to_a_strong_random_secret_key
FLASK_DEBUG=False
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# -----------------------------------------------------------------------------
# Research API Keys (OPTIONAL — free tiers available)
# -----------------------------------------------------------------------------
# Semantic Scholar: https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# PubMed / NCBI: https://www.ncbi.nlm.nih.gov/account/
PUBMED_API_KEY=

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
MAX_PAPERS_PER_SEARCH=10
MAX_HISTORY_ENTRIES=100
EXPORT_DIR=exports
LOG_LEVEL=INFO
